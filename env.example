# ─── Google OAuth ────────────────────────────────────────────────────────────
# Obtenha em: https://console.cloud.google.com
# Crie: APIs & Services > Credentials > OAuth 2.0 Client ID > Web application

GOOGLE_CLIENT_ID=seu_client_id_aqui.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=seu_client_secret_aqui
GOOGLE_REDIRECT_URI=http://localhost:3000/classroom/callback

# ─── App ──────────────────────────────────────────────────────────────────────
APP_URL=https://leiturinhas.app
SESSION_SECRET=troque_por_string_aleatoria_longa
PORT=3000
NODE_ENV=development

# ─── Banco de dados (Supabase) ────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:[senha]@db.[projeto].supabase.co:5432/postgres
